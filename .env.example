# Copy to .env on the host before `docker compose up -d`.
# Caddy reaches the container at <container_name>:$PORT (see docker-compose.yml).

NODE_ENV=production
PORT=3000

# HEIC input is enabled by default. Set to 0 to refuse HEIC uploads (the
# pipeline still needs libheif's heif-convert + heif-enc to actually round-trip).
# HEIC_IMPORT=0
